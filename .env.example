DATABASE_URL=postgresql://user:password@localhost:5432/coreinventory
# Alternative for SQLite: sqlite:///./coreinventory.db
# Alternative for MySQL: mysql+pymysql://user:password@localhost:3306/coreinventory

# Email Configuration (for password reset emails)
# For Gmail: Use App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=your-email@gmail.com
FROM_NAME=CoreInventory

# For other email providers:
# Outlook: smtp.office365.com (port 587)
# Yahoo: smtp.mail.yahoo.com (port 587)
# Custom SMTP: your-smtp-server.com (port 587 or 465)
